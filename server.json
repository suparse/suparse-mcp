{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.suparse/suparse-mcp",
  "title": "Suparse Document Processing",
  "description": "Extract structured data from PDFs and documents with Suparse AI OCR.",
  "repository": {
    "url": "https://github.com/suparse/suparse-mcp",
    "source": "github"
  },
  "websiteUrl": "https://www.suparse.com",
  "categories": ["ai-ml", "developer-tools", "productivity"],
  "version": "1.3.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@suparse/mcp",
      "version": "1.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SUPARSE_API_KEY",
          "description": "Suparse API key used to authenticate requests.",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "SUPARSE_API_URL",
          "description": "Optional Suparse API base URL override.",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "categories": ["ai-ml", "developer-tools", "productivity"],
      "tags": [
        "ocr",
        "document-processing",
        "pdf",
        "data-extraction",
        "ai",
        "llm",
        "structured-data"
      ],
      "links": {
        "homepage": "https://www.suparse.com",
        "docs": "https://www.suparse.com/docs",
        "repository": "https://github.com/suparse/suparse-mcp",
        "support": "https://github.com/suparse/suparse-mcp/issues"
      }
    }
  }
}
